/**
 * @file example_discrete_distributions.cpp
 * @brief Examples of discrete probability distributions
 */

#include <iostream>
#include <iomanip>
#include "discrete_distributions.hpp"

int main()
{
    std::cout << std::fixed << std::setprecision(4);

    std::cout << "=== Discrete Distributions Examples ===\n\n";

    // Binomial Distribution
    std::cout << "1. Binomial Distribution (n=10, p=0.5)\n";
    std::cout << "   PMF at k=5: " << statcpp::binomial_pmf(5, 10, 0.5) << "\n";
    std::cout << "   CDF at k=5: " << statcpp::binomial_cdf(5, 10, 0.5) << "\n";
    std::cout << "   Median: " << statcpp::binomial_quantile(0.5, 10, 0.5) << "\n";
    std::cout << "   Random sample: " << statcpp::binomial_rand(10, 0.5) << "\n\n";

    // Poisson Distribution
    std::cout << "2. Poisson Distribution (λ=3.0)\n";
    std::cout << "   PMF at k=3: " << statcpp::poisson_pmf(3, 3.0) << "\n";
    std::cout << "   CDF at k=5: " << statcpp::poisson_cdf(5, 3.0) << "\n";
    std::cout << "   95th percentile: " << statcpp::poisson_quantile(0.95, 3.0) << "\n";
    std::cout << "   Random sample: " << statcpp::poisson_rand(3.0) << "\n\n";

    // Bernoulli Distribution
    std::cout << "3. Bernoulli Distribution (p=0.7)\n";
    std::cout << "   PMF at k=1: " << statcpp::bernoulli_pmf(1, 0.7) << "\n";
    std::cout << "   CDF at k=0: " << statcpp::bernoulli_cdf(0, 0.7) << "\n";
    std::cout << "   Median: " << statcpp::bernoulli_quantile(0.5, 0.7) << "\n";
    std::cout << "   Random sample: " << statcpp::bernoulli_rand(0.7) << "\n\n";

    // Discrete Uniform Distribution
    std::cout << "4. Discrete Uniform Distribution (a=1, b=6)\n";
    std::cout << "   PMF at k=3: " << statcpp::discrete_uniform_pmf(3, 1, 6) << "\n";
    std::cout << "   CDF at k=3: " << statcpp::discrete_uniform_cdf(3, 1, 6) << "\n";
    std::cout << "   Median: " << statcpp::discrete_uniform_quantile(0.5, 1, 6) << "\n";
    std::cout << "   Random sample: " << statcpp::discrete_uniform_rand(1, 6) << "\n\n";

    // Geometric Distribution
    std::cout << "5. Geometric Distribution (p=0.3)\n";
    std::cout << "   PMF at k=2: " << statcpp::geometric_pmf(2, 0.3) << "\n";
    std::cout << "   CDF at k=5: " << statcpp::geometric_cdf(5, 0.3) << "\n";
    std::cout << "   Median: " << statcpp::geometric_quantile(0.5, 0.3) << "\n";
    std::cout << "   Random sample: " << statcpp::geometric_rand(0.3) << "\n\n";

    return 0;
}
